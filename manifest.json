{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",

  "name":       "Bluff Multiplayer Card Game",
  "short_name": "Bluff",
  "description": "An online multiplayer version of the classic bluffing card game — claim your cards, catch the liars, or become one.",

  "start_url": "index.html",
  "id":        "bluff-multiplayer-v1",
  "scope":     "./",

  "display":     "standalone",
  "orientation": "portrait",

  "background_color": "#1a1a1a",
  "theme_color":      "#0f0f0f",

  "lang": "en-US",
  "dir":  "ltr",

  "categories": ["games", "entertainment"],

  "icons": [
    {
      "src":     "icon-192.png",
      "sizes":   "192x192",
      "type":    "image/png",
      "purpose": "any maskable"
    },
    {
      "src":     "icon-512.png",
      "sizes":   "512x512",
      "type":    "image/png",
      "purpose": "any maskable"
    }
  ],

  "screenshots": [],

  "related_applications": [],
  "prefer_related_applications": false,

  "shortcuts": [
    {
      "name":       "Quick Play",
      "short_name": "Play",
      "description": "Jump straight into a game lobby.",
      "url":         "index.html?action=quickplay",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    }
  ]
}
